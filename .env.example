# =============================================
# AI-Commerce Orchestrator — Variables de entorno
# Copiar a .env y completar valores reales.
# ¡NUNCA subir .env al repositorio!
# =============================================

# Entorno
ENV=development

# Backend
BACKEND_PORT=8000

# Base de datos PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_NAME=ai_commerce
DB_USER=postgres
DB_PASSWORD=change_me_in_env

# Redis (cache + broker secundario)
REDIS_HOST=redis
REDIS_PORT=6379

# RabbitMQ (message broker)
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASS=change_me_in_env

# LLM
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o-mini
