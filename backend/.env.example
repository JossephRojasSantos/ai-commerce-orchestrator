APP_ENV=development
APP_VERSION=0.1.0
DATABASE_URL=postgresql+asyncpg://postgres:change_me@db:5432/ai_commerce
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=["http://localhost:3000"]
LOG_LEVEL=INFO
LOG_FORMAT=json
METRICS_ENABLED=true

# WooCommerce REST API
WC_BASE_URL=https://tiendamagica.shop/wp-json/wc/v3
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_TIMEOUT=10
WC_MAX_RETRIES=3
WC_CACHE_TTL_PRODUCTS=300
WC_CACHE_TTL_ORDERS=60

# Chat
CHAT_SESSION_TTL=3600
CHAT_MAX_HISTORY=50
CHAT_RATE_LIMIT_PER_MIN=30
CHAT_ALLOWED_ORIGINS=https://tiendamagica.shop

# WhatsApp Cloud API (Meta)
# Obtener desde: https://developers.facebook.com/ > WhatsApp > API Setup
WA_PHONE_ID=
WA_SANDBOX_PHONE_ID=
WA_ACCESS_TOKEN=
WA_WEBHOOK_VERIFY_TOKEN=
WA_APP_SECRET=
WA_API_VERSION=v18.0
WA_RATE_LIMIT_PER_HOUR=10
