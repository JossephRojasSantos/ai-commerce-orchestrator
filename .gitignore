__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/
env/
*.egg

# Node (por si se agrega frontend)
node_modules/
npm-debug.log*
yarn-debug.log*

# Docker
.docker/

# macOS
.DS_Store
.AppleDouble
._*
.Spotlight-V100
.Trashes

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
logs/

# Tests
.pytest_cache/
.coverage
htmlcov/
.tox/

# Temporales
tmp/
temp/
*.tmp
*.bak
