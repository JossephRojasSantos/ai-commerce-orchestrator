# =============================================
# AI-Commerce Orchestrator — Variables de entorno
# Copiar a .env y completar valores reales.
# ¡NUNCA subir .env al repositorio!
# =============================================

# Entorno
ENV=development

# Backend
BACKEND_PORT=8000

# Base de datos PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_NAME=ai_commerce
DB_USER=postgres
DB_PASSWORD=change_me_in_env

# Redis (cache + broker secundario)
REDIS_HOST=redis
REDIS_PORT=6379

# RabbitMQ (message broker)
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASS=change_me_in_env

# LLM — OpenRouter (https://openrouter.ai)
LLM_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx
LLM_API_BASE=https://openrouter.ai/api/v1
LLM_MODEL_CHAT=openai/gpt-4o-mini
LLM_MODEL_ROUTER=google/gemini-2.0-flash
LLM_MODEL_WHATSAPP=openai/gpt-4o-mini
LLM_FALLBACK_CHAT=anthropic/claude-haiku-4-5
LLM_FALLBACK_ROUTER=meta-llama/llama-3.1-8b-instruct
OPENROUTER_REFERER=https://tiendamagica.shop
OPENROUTER_APP_NAME=Tienda Magica
ORCHESTRATOR_RATE_LIMIT_PER_MIN=20

# Auth & rate limiting
ALLOWED_API_KEYS=["key-web-changeme"]
IP_RATE_LIMIT_PER_MIN=60
